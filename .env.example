# === Local (development) ===
SECRET_KEY=dev-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# === Producción (Vercel / Render) ===
# Genera un SECRET_KEY fuerte: python -c "import secrets; print(secrets.token_urlsafe(50))"
# SECRET_KEY=...

# DATABASE_URL es OBLIGATORIO en producción. SQLite no sirve en serverless.
# Opciones gratuitas:
#   Neon:     https://neon.tech     (Postgres serverless)
#   Supabase: https://supabase.com   (Postgres + extras)
#   Vercel:   "Storage > Postgres"   (integrado en dashboard)
# Formato: postgres://user:password@host:5432/dbname?sslmode=require
# DATABASE_URL=postgres://...

# Cloudinary (obligatorio en Vercel para imágenes de posts)
# Crea cuenta gratis en https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
